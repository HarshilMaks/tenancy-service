# =============================================================================
# Tenancy Service Environment Configuration - EXAMPLE
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# Environment & Debug
ENVIRONMENT=development
DEBUG=true
SERVICE_DEBUG=true
TESTING=false

# =============================================================================
# Database Configuration
# =============================================================================

# ⚠️ IMPORTANT: Set DATABASE_URL in environment or .env (not committed)
# DATABASE_URL takes precedence over individual settings below
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Individual settings (only used if DATABASE_URL not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tenancy_service
DATABASE_USER=postgres
# ⚠️ IMPORTANT: Set this to your actual database password
DATABASE_PASSWORD=your_secure_password_here
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# Redis Configuration (for caching/sessions)
# =============================================================================

# ⚠️ IMPORTANT: Set REDIS_URL in environment or .env (not committed)
# REDIS_URL takes precedence over individual settings below
# REDIS_URL=redis://default:password@host:6379

# Individual settings (only used if REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# Service Configuration
# =============================================================================

SERVICE_NAME=tenancy_service
SERVICE_VERSION=1.0.0
SERVICE_API_HOST=0.0.0.0
SERVICE_API_PORT=8000
SERVICE_API_PREFIX=/api/v1
SERVICE_WORKERS=4

# Security - Hosts & CORS
SERVICE_ALLOWED_HOSTS=*
SERVICE_CORS_ORIGINS=*
SERVICE_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Correlation-ID,X-Request-ID
SERVICE_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
SERVICE_CORS_ALLOW_CREDENTIALS=true
SERVICE_CORS_MAX_AGE=600

# Rate Limiting
SERVICE_RATE_LIMIT_ENABLED=true
SERVICE_RATE_LIMIT_REQUESTS=100
SERVICE_RATE_LIMIT_WINDOW=60

# =============================================================================
# Security Configuration
# =============================================================================

# ⚠️ CRITICAL: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Secret key for encryption (minimum 32 characters)
SECRET_KEY=your_secret_key_here_minimum_32_characters_long

# JWT signing secret (minimum 32 characters)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long

# =============================================================================
# Observability Configuration
# =============================================================================

# Logging
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_LOG_FORMAT=json
OBSERVABILITY_CORRELATION_ID_ENABLED=true
OBSERVABILITY_PII_MASKING_ENABLED=true

# Metrics
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PORT=9090
OBSERVABILITY_METRICS_PATH=/metrics

# Tracing
OBSERVABILITY_TRACING_ENABLED=true
OBSERVABILITY_TRACING_SERVICE_NAME=tenancy-service
OBSERVABILITY_TRACING_SAMPLE_RATE=0.1

# Health Checks
OBSERVABILITY_HEALTH_ENABLED=true
OBSERVABILITY_HEALTH_PATH=/health

# =============================================================================
# Tenant Configuration
# =============================================================================

TENANT_MAX_ORGANIZATIONS=1000
TENANT_DEFAULT_EDITION=free
TENANT_TRIAL_DURATION_DAYS=30
TENANT_DEFAULT_REGION=us-east-1

# =============================================================================
# External Service URLs
# =============================================================================

API_GATEWAY_URL=http://localhost:8000

# Other microservices (when available)
BILLING_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:8002
ANALYTICS_SERVICE_URL=http://localhost:8003

# Message Queue
EVENT_BUS_URL=http://localhost:9092
MESSAGING_RABBITMQ_HOST=localhost
MESSAGING_RABBITMQ_PORT=5672
MESSAGING_RABBITMQ_USER=guest
# ⚠️ IMPORTANT: Set this to your actual RabbitMQ password
MESSAGING_RABBITMQ_PASSWORD=your_rabbitmq_password_here

# =============================================================================
# Development & Testing
# =============================================================================

# Test Database (optional - falls back to main DB with _test suffix)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tenancy_service_test

# Development tools
DEV_AUTO_RELOAD=true
DEV_SHOW_SQL_QUERIES=false
